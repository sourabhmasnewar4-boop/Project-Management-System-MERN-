{
  "name": "medinex-pm-backend",
  "version": "1.0.0",
  "description": "Backend API for MERN Project Management Dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "node --watch server.js",
    "seed": "node seed.js",
    "client": "cd ../frontend && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.1",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}